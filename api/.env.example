OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini
# The LLM path is enabled by default. If no browser or server API key is
# available, chat falls back to deterministic local MAS replies.
LLM_ENABLED=true
LLM_TIMEOUT_SECONDS=6
LLM_FAILURE_COOLDOWN_SECONDS=60
# Optional: point to any OpenAI-compatible chat completions endpoint.
# OPENAI_BASE_URL=https://api.openai.com/v1
